# Intake repos are disposable clone worktrees.
# Keep only intake metadata docs in git.
/intake_repos/*
!/intake_repos/README.md

# Unified knowledge shard
/repos/*
!/repos/knowledge/
!/repos/knowledge/**

# Legacy shard directories (archived)
/llm_repos/
/ssh_repos/

# Non-canonical local corpora (scratch/source clones)
/cli_repos/
/go_repos/
/structured_outputs/
/uncat_repos/
/vector_db/

# Local noise (kept last so these still win inside allowlisted folders)
**/.DS_Store
**/__pycache__/
**/*.py[cod]
**/.tmp/
**/.knowledge-history/
/.venv/
/reports/ws6_deep_integration/deep_audit_*.md

# Clone working directory (disposable repo clones for deep file generation)
workspace/clones/

# Batch orchestrator runtime specs (per-run, not canonical)
batch_spec.yaml

# WS7 read model — derived artifact, rebuilt on every compile
knowledge.db

# Dolt database files (added by bd init)
.dolt/
*.db
